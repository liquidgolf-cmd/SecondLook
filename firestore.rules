rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Users can only read/write their own risk events
      match /riskEvents/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Family connections
    match /familyConnections/{connectionId} {
      // Any authenticated user can read (needed to query by invite_token when accepting invite)
      allow read: if request.auth != null;

      // Only the senior can create a connection for themselves
      allow create: if request.auth != null
        && request.resource.data.senior_user_id == request.auth.uid;

      // Senior can update/delete their own connections
      // Family member can update (to set family_user_id when accepting invite)
      allow update: if request.auth != null && (
        resource.data.senior_user_id == request.auth.uid
        || resource.data.family_user_id == request.auth.uid
        || (
          // Accepting invite: family_user_id was null, now being set to current user
          resource.data.family_user_id == null
          && request.resource.data.family_user_id == request.auth.uid
        )
      );

      allow delete: if request.auth != null
        && resource.data.senior_user_id == request.auth.uid;
    }
  }
}
